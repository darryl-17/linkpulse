# LinkPulse — Environment Variables
# Copy this file to .env.local and fill in values

# App base URL (used for generating short links in emails or external contexts)
# In production, Vercel sets this automatically via VERCEL_URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Future: Add Vercel KV or database credentials here for persistent storage
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
